{
    "paths": {
        "reddit_chunks": "hdfs:///data/chunks/AskReddit_comments",
        "clean_corpus": "hdfs:///data/clean_corpus",
        "out_dir": "hdfs:///outputs"
    },
    "params": {
        "min_token_count": 100,
        "min_clean_ratio_score": 3.0,
        "spike_min_clean_ratio_score": 0.0,
        "min_spike_score": 2.3,
        "min_spike_periods": 1,
        "monthly_window_periods": 6,
        "yearly_window_periods": 3,
        "min_baseline_periods": 3,
        "min_period_count": 10,
        "min_baseline_total_tokens": 25000,
        "smoothing_alpha": 1.0
    },
    "score_params": {
        "clean_ratio_c": 3.0,
        "clean_ratio_s": 0.4,
        "spike_monthly_c": 2.3,
        "spike_monthly_s": 0.4,
        "spike_yearly_c": 2.3,
        "spike_yearly_s": 0.4,
        "reliability_log": 101,
        "spike_boost_weight": 0.6,
        "power_transform": 0.4,
        "rank_top_k": 5000,
        "rank_top_k_floor": 0.8,
