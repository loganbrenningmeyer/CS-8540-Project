    "filter": {
        "min_len": 3,
        "alphabetic_only": false,
        "allow_numbers": false,
        "allow_hyphen": true,
        "allow_apostrophe": true,
        "allow_underscore": false
    },
    "lexicons": {
        "profanity": "hdfs:///data/lexicons/profanity.txt",
        "typos": "hdfs:///data/lexicons/typos.txt",
        "reddit_jargon": "hdfs:///data/lexicons/reddit_jargon.txt",
        "subreddits": "hdfs:///data/lexicons/subreddits.txt"
